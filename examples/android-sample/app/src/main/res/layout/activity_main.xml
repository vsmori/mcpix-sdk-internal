<?xml version="1.0" encoding="utf-8"?>
<!-- UI minimalista: botão dispara o flow + TextView mostra resultado.
     Layout linear vertical, padding generoso para legibilidade. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="mcpix-sdk demo"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnRun"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rodar fluxo: register → generate → validate"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/output"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:text="Toque no botão para iniciar."
        android:scrollbars="vertical"
        android:textIsSelectable="true" />

</LinearLayout>
